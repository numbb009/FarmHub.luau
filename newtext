-- 3. Fireball Farm
CreateButton(ScrollFrame, "Fireball Farm", function()
    task.spawn(function()
        local remote = ReplicatedStorage:WaitForChild("SkillsInRS", 9e9):WaitForChild("RemoteEvent", 9e9)
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")

        while not stopAll do
            -- Get the correct dummy folder (dummies or 5k_dummies) based on location
            local dummies = GetCurrentDummyFolder()
            if not dummies then task.wait(0.5) continue end

            -- Find the nearest dummy in the folder
            local nearest = nil
            local shortestDist = math.huge
            for _, dummy in pairs(dummies:GetChildren()) do
                local hrp = dummy:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (hrp.Position - root.Position).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        nearest = dummy
                    end
                end
            end

            -- Fire at the nearest dummy
            if nearest and nearest:FindFirstChild("HumanoidRootPart") then
                pcall(function() 
                    remote:FireServer(nearest.HumanoidRootPart.Position, "NewFireball") 
                end)
            end

            wait(math.random(15, 25)/10)
        end
    end)
end)   
