-- zone detection for fireball and lightning ball
local function GetCurrentDummyFolder()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Define the center position of your 5k dummy area (Get these coordinates from your map)
    local k5AreaCenter = Vector3.new(X, Y, Z) -- Replace X, Y, Z with actual coordinates
    local distanceToK5 = (root.Position - k5AreaCenter).Magnitude

    -- If you're within 50 studs of the 5k area, use 5k_dummies
    if distanceToK5 < 50 then
        local map = Workspace:FindFirstChild("MAP")
        return map and map:FindFirstChild("5k_dummies")
    else
        -- Otherwise, use the regular dummies
        local map = Workspace:FindFirstChild("MAP")
        return map and map:FindFirstChild("dummies")
    end
end   

