-- 2. 5k Dummy Teleport + Farm
CreateButton(ScrollFrame, "Teleport + Farm (5k Dummy)", function()
    task.spawn(function()
        -- 1. Get Paths (Same as regular script)
        local map = Workspace:WaitForChild("MAP", 10)
        local dummiesFolder = map:WaitForChild("5k_dummies", 10)
        local remote = ReplicatedStorage:WaitForChild("jdskhfsIIIllliiIIIdchgdIiIIIlIlIli", 10)
        
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")

        -- 2. Simple Helper to find a valid 5k dummy
        local function Get5kTarget()
            for _, v in pairs(dummiesFolder:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
                    -- Check specifically for 5k HP
                    if v.Humanoid.Health > 0 and v.Humanoid.MaxHealth >= 4900 then
                        return v
                    end
                end
            end
            return nil
        end

        -- 3. Wait for a dummy to actually exist (Prevents crash on empty folder)
        local target = nil
        for i = 1, 20 do
            target = Get5kTarget()
            if target then break end
            task.wait(0.2)
        end

        if not target then warn("No 5k dummies found!"); return end

        -- 4. Teleport & Farm (Same logic as regular)
        root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
        
        while not stopAll do
            -- Re-check target in case it dies
            if not target or not target.Parent or target.Humanoid.Health <= 0 then
                target = Get5kTarget()
            end
            
            if target then
                pcall(function() remote:FireServer(target.Humanoid, 2) end)
            end
            task.wait(math.random(4, 7)/10)
        end
    end)
end)   
